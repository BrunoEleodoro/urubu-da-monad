# Public app URL used by Farcaster metadata and the miniapp manifest.
NEXT_PUBLIC_URL="https://urubu.money"

# Optional: add these after generating an account association in Warpcast.
FARCASTER_HEADER=
FARCASTER_PAYLOAD=
FARCASTER_SIGNATURE=

# Required on the server to seal the passkey wallet cookie.
PASSKEY_WALLET_SECRET=

# Passkey defaults for production on urubu.money. Override locally if needed.
PASSKEY_RP_ID="urubu.money"
PASSKEY_ORIGIN="https://urubu.money"

# Required on the server for direct Orda SDK quotes and status polling.
ORDA_CLIENT_ID=
ORDA_CLIENT_SECRET=

# Optional override. Defaults to https://api.orda.network/v1
ORDA_API_BASE_URL=
