# Public app URL used by Farcaster metadata and the miniapp manifest.
NEXT_PUBLIC_URL="https://urubu-da-monad.vercel.app"

# Optional: add these after generating an account association in Warpcast.
FARCASTER_HEADER=
FARCASTER_PAYLOAD=
FARCASTER_SIGNATURE=

# Required for the Orda widget connection modal.
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=

# Required on the server for Orda JWT generation.
ORDA_CLIENT_ID=
ORDA_CLIENT_SECRET=

# Optional override. Defaults to https://api.orda.network/v1
NEXT_PUBLIC_ORDA_API_BASE_URL=
