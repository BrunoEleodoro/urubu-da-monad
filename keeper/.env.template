# ── RPC ───────────────────────────────────────────────────────────────────────
RPC_URL=https://monad-mainnet.drpc.org   # HTTP endpoint (required)
WS_URL=wss://monad-mainnet.drpc.org      # WebSocket endpoint (optional, used for event subscriptions)

# ── Keeper identity ───────────────────────────────────────────────────────────
# Must be the owner of the Binary contract — settle() is restricted to trader || owner.
KEEPER_PRIVATE_KEY=0x...                 # 0x-prefixed hex private key

# ── Contract addresses ────────────────────────────────────────────────────────
BINARY_ADDRESS=0x...                     # Deployed Binary contract address

# ── Scan range ────────────────────────────────────────────────────────────────
# Block number at which the Binary contract was deployed.
# Set this to avoid scanning from genesis on every startup.
FROM_BLOCK=0

# ── Timing ────────────────────────────────────────────────────────────────────
# How often (ms) the keeper polls the oracle and checks positions.
# Monad has ~500ms block time — 1000ms is a safe default.
POLL_INTERVAL_MS=1000
